# Copy this file to .env and fill in your keys.
# Never commit .env to git.

# Anthropic API — for Claude (adversarial reads, synthesis, draft generation)
ANTHROPIC_API_KEY=

# Parallel.ai — for structured deep research
PARALLEL_API_KEY=

# Apify — for scraping social signals, reviews, communities
APIFY_TOKEN=

# Optional: default mode for new hypotheses (lean | full)
DEFAULT_MODE=lean

# Optional: default budget cap per hypothesis in USD
DEFAULT_BUDGET_USD=50
